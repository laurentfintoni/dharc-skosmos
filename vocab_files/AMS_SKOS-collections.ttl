  skos:closeMatch <http://vocab.getty.edu/page/aat/300028772>;
  dct:description "Iscrizioni che indicano la proprietà o che riportano il nome dell’individuo, dell’ente o dell’istituzione responsabile"@it,
    "Inscriptions marking ownership or bearing the name of an individual, entity, or institution in charge"@en;
  skos:inScheme <http://w3id.org/AMSHistorica/thesaurus> .

