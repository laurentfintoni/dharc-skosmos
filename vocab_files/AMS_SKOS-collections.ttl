  skos:exactMatch <https://ontology.inscriptiones.org/type_of_inscription/Label>;
  skos:broader ams:iscrizioni_identificative;
  skos:related ams:owner, ams:trademark;
  skos:altLabel "Label"@en;
  dct:description "Iscrizioni che forniscono descrizioni o informazioni identificative relative a oggetti, manufatti o immagini."@it,
    "Inscriptions providing descriptions or identifying information for objects, artifacts, or images."@en;
  skos:inScheme <http://w3id.org/AMSHistorica/thesaurus> .

