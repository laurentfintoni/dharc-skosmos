  dct:description "Famiglia di piante angiosperme dicotiledoni che comprende specie erbacee, arbustive o arboree, molte delle quali di interesse alimentare o ornamentale, come patata, pomodoro e peperone."@it,
    "A family of dicotyledonous angiosperms including herbaceous, shrubby, or arboreal species, many of which are important as food or ornamental plants, such as potato, tomato, and pepper."@en;
  skos:narrower ams:patata, ams:melanzana, ams:pomodoro, ams:peperone;
  skos:inScheme <http://w3id.org/AMSHistorica/thesaurus> .

ams:dicotiledoni a skos:Concept;
  skos:prefLabel "Dicotiledoni"@it, "Dicotyledons"@en;
  skos:exactMatch <https://thes.bncf.firenze.sbn.it/termine.php?id=1034>;
